# AI Service Mesh — production configuration template
MESH_HOST=0.0.0.0
MESH_PORT=8090
MESH_ENV=production

# Required in production: comma-separated origins (empty = no CORS)
MESH_CORS_ORIGINS=http://localhost:5173,http://localhost:8090

# API auth (Bearer). Unset in dev allows open read; writes always require token if set.
MESH_API_TOKEN=change-me-in-production

# Admin: agent registration, mesh control
MESH_ADMIN_TOKEN=change-me-admin

# Local dev/scripts only (docker-compose requires strong tokens, no defaults):
# MESH_ALLOW_INSECURE_TOKENS=1

# Optional upstream AIMarket hub for federated discovery
MESH_HUB_URL=http://127.0.0.1:9080
MESH_SKIP_DEMO_CAPABILITIES=true
MESH_DATA_DIR=./backend/.mesh_data

# Storage: omit for SQLite (default). Production HA:
# MESH_DATABASE_URL=postgresql://user:pass@localhost:5432/mesh
# Or standard env (same as AIMarket Hub / plugins):
# DATABASE_URL=postgresql://user:pass@localhost:5432/mesh

# Rate limit (requests per minute per IP)
MESH_RATE_LIMIT=120

# Dead-letter in-progress tasks after N seconds (background sweep every 60s)
MESH_TASK_STALE_SECONDS=600

# --- Security hardening (safe defaults; enable per environment) ---
# SEC-01: browser BFF POST /v1/ui/tasks is disabled by default (fail-closed).
# Enable ONLY behind an authenticated reverse proxy; it also enforces the
# MESH_CORS_ORIGINS allowlist via the request Origin header.
# MESH_ALLOW_UI_WRITES=1
#
# SEC-08: only trust X-Forwarded-For when behind a proxy that rewrites it,
# otherwise clients can spoof it to evade per-IP rate limiting.
# MESH_TRUST_FORWARDED_FOR=1
#
# SEC-08b: when false, read endpoints (agents/tasks/stats/activity) require the
# API token too. Default true keeps the public dashboard working.
MESH_PUBLIC_READ=true
#
# SEC-10: expose backend/storage details on /health (keep off in production).
# MESH_HEALTH_VERBOSE=1
